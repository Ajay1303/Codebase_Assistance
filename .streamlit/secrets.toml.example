# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────────────────
# This file is used by Streamlit Cloud for secret management.
# DO NOT commit this file to GitHub — it is already in .gitignore
#
# On Streamlit Cloud, add these via:
#   App Settings → Secrets → paste contents below
# ─────────────────────────────────────────────────────────────────────────────

GROQ_API_KEY = "your_groq_api_key_here"
